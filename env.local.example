# ─── Agora ────────────────────────────────────────────────────────────────────
# Required: found in Agora Console → your project → "App ID"
NEXT_PUBLIC_AGORA_APP_ID=

# Required: found in Agora Console → your project → "App Certificate"
# Server-side only. Never expose this in client code.
NEXT_AGORA_APP_CERTIFICATE=

# UID the AI agent joins the channel with.
# Must match the agentUid set in app/api/invite-agent/route.ts.
# Default: 123456
NEXT_PUBLIC_AGENT_UID=123456

# Optional BYOK examples:
# Uncomment the matching blocks in app/api/invite-agent/route.ts if you want to bring
# your own vendor credentials instead of using the Agora-managed defaults.
# NEXT_DEEPGRAM_API_KEY=
# NEXT_LLM_URL=https://api.openai.com/v1/chat/completions
# NEXT_LLM_API_KEY=
# NEXT_ELEVENLABS_API_KEY=
# NEXT_ELEVENLABS_VOICE_ID=

# ─── Optional: custom LLM proxy ───────────────────────────────────────────────
# Only needed if you use app/api/chat/completions as a custom OpenAI-compatible proxy.

# ─── Agent behavior ───────────────────────────────────────────────────────────
# Optional opening line override
# NEXT_AGENT_GREETING=Hi there! I'm Ada, your virtual assistant from Agora. How can I help?
